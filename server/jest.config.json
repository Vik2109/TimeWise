{
  "testEnvironment": "node",
  "testMatch": ["**/tests/**/*.test.js"],
  "testTimeout": 30000,
  "verbose": true,
  "forceExit": true,
  "detectOpenHandles": true,
  "collectCoverage": false,
  "coverageDirectory": "coverage",
  "coverageReporters": ["text", "lcov"],
  "collectCoverageFrom": [
    "routes/**/*.js",
    "models/**/*.js",
    "middleware/**/*.js",
    "utils/**/*.js",
    "!**/node_modules/**",
    "!**/tests/**"
  ]
}
